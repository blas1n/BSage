# LLM Configuration
# For Anthropic Claude:
LLM_MODEL=anthropic/claude-sonnet-4-20250514
LLM_API_KEY=
LLM_API_BASE=
# For Ollama (use ollama_chat/ prefix — NOT ollama/ — to get /api/chat with tool use support):
# LLM_MODEL=ollama_chat/llama3.2
# LLM_API_BASE=http://localhost:11434

# Embedding / RAG (optional — enables semantic search)
# For OpenAI:
# EMBEDDING_MODEL=text-embedding-3-small
# For Ollama local:
# EMBEDDING_MODEL=ollama/nomic-embed-text
# EMBEDDING_API_BASE=http://localhost:11434
EMBEDDING_MODEL=
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=
# RAG_INDEX_PATH=  # default: {VAULT_PATH}/.rag/index.db

# Authentication (BSVibe)
BSVIBE_AUTH_URL=https://auth.bsvibe.dev

# bsvibe-authz — OpenFGA + service JWT (Phase 0 P0.5)
# Empty OPENFGA_API_URL disables OpenFGA enforcement (local dev mode).
OPENFGA_API_URL=
OPENFGA_STORE_ID=
OPENFGA_AUTH_MODEL_ID=
OPENFGA_AUTH_TOKEN=
# Shared secret with BSVibe-Auth POST /api/service-tokens/issue (HS256).
SERVICE_TOKEN_SIGNING_SECRET=
# Default tenant id used for non-authenticated writes (cron / migration).
DEFAULT_TENANT_ID=tenant-default
# User session JWT verification (HS256 in Phase 0; JWKS in Phase 0.4-후속).
USER_JWT_SECRET=
USER_JWT_ALGORITHM=HS256
USER_JWT_AUDIENCE=bsvibe
USER_JWT_ISSUER=https://auth.bsvibe.dev

# Paths
VAULT_PATH=./vault
SKILLS_DIR=./skills
TMP_DIR=./tmp
CREDENTIALS_DIR=./.credentials

# Credential encryption (Fernet)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required in production. When unset, .credentials/*.json are stored as plaintext (legacy).
CREDENTIAL_ENCRYPTION_KEY=
# Comma-separated retired keys, accepted for decryption during rotation.
# CREDENTIAL_ENCRYPTION_RETIRED_KEYS=

# Runtime
SAFE_MODE=true
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8000
LOG_LEVEL=info

# Frontend
VITE_ALLOWED_HOSTS=

# bsvibe-audit (Phase Audit Batch 2) — outbox-pattern audit emission.
# Empty BSVIBE_AUTH_AUDIT_URL keeps the relay disabled (events still queue
# locally so wiring can be inspected, but nothing is shipped). Set both
# values once BSVibe-Auth's POST /api/audit/events endpoint is online.
BSVIBE_AUTH_AUDIT_URL=
BSVIBE_AUTH_AUDIT_SERVICE_TOKEN=
AUDIT_BATCH_SIZE=50
AUDIT_RELAY_INTERVAL_S=5.0
AUDIT_MAX_RETRIES=5
# Optional explicit override; only meaningful when BSVIBE_AUTH_AUDIT_URL is set.
# AUDIT_RELAY_ENABLED=true
AUDIT_SERVICE_NAME=bsage
