# LLM Configuration
# For Anthropic Claude:
LLM_MODEL=anthropic/claude-sonnet-4-20250514
LLM_API_KEY=
LLM_API_BASE=
# For Ollama (use ollama_chat/ prefix — NOT ollama/ — to get /api/chat with tool use support):
# LLM_MODEL=ollama_chat/llama3.2
# LLM_API_BASE=http://localhost:11434

# Embedding / RAG (optional — enables semantic search)
# For OpenAI:
# EMBEDDING_MODEL=text-embedding-3-small
# For Ollama local:
# EMBEDDING_MODEL=ollama/nomic-embed-text
# EMBEDDING_API_BASE=http://localhost:11434
EMBEDDING_MODEL=
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=
# RAG_INDEX_PATH=  # default: {VAULT_PATH}/.rag/index.db

# Authentication (Supabase)
SUPABASE_JWT_SECRET=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Paths
VAULT_PATH=./vault
SKILLS_DIR=./skills
TMP_DIR=./tmp
CREDENTIALS_DIR=./.credentials

# Runtime
SAFE_MODE=true
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8000
LOG_LEVEL=info

# Frontend
VITE_ALLOWED_HOSTS=

# Frontend Authentication (Supabase — public keys, safe to expose)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
