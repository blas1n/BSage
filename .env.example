# LLM Configuration
# For Anthropic Claude:
LLM_MODEL=anthropic/claude-sonnet-4-20250514
LLM_API_KEY=
LLM_API_BASE=
# For Ollama (use ollama_chat/ prefix — NOT ollama/ — to get /api/chat with tool use support):
# LLM_MODEL=ollama_chat/llama3.2
# LLM_API_BASE=http://localhost:11434

# Paths
VAULT_PATH=./vault
SKILLS_DIR=./skills
TMP_DIR=./tmp
CREDENTIALS_DIR=./.credentials

# Runtime
SAFE_MODE=true
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8000
LOG_LEVEL=info
