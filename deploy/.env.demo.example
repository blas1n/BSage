# BSage DEMO environment template (deploy/.env.demo).
#
# Copy to `deploy/.env.demo` and fill in real values. `.env.demo` is gitignored.
# This file configures the PUBLIC INTERACTIVE DEMO stack — separate from prod.
#
# Generate secrets:
#   openssl rand -hex 32      # for DEMO_JWT_SECRET

# ─── Demo session signing (per-product, NOT shared with prod auth.bsvibe.dev) ───
DEMO_JWT_SECRET=

# ─── LLM (mock mode for demo — scripted responses, no real API calls) ───
LLM_MODEL=mock
LLM_API_KEY=
LLM_API_BASE=

# ─── Embedding (disabled in demo) ───
EMBEDDING_MODEL=
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=

# ─── BSVibe Auth (demo backend uses DEMO_JWT_SECRET, not Supabase) ───
BSVIBE_AUTH_URL=https://auth.bsvibe.dev
SUPABASE_JWT_SECRET=
SUPABASE_URL=

# ─── SafeMode FORCED ON in demo (no plugin outbound, no shell escape) ───
SAFE_MODE=true

# ─── CORS — demo frontend domain only ───
CORS_ORIGINS=["https://demo-sage.bsvibe.dev"]

# ─── Logging ───
LOG_LEVEL=INFO
