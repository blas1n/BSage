# =============================================================================
# BSage Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git!
# =============================================================================

# ── AI / LLM ────────────────────────────────────────────────────
LLM_MODEL=anthropic/claude-haiku-4-5-20251001
LLM_API_KEY=your_llm_api_key_here
LLM_API_BASE=

# ── Embedding (optional) ────────────────────────────────────────
EMBEDDING_MODEL=
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=

# ── Authentication (BSVibe, optional) ─────────────────────────
BSVIBE_AUTH_URL=https://auth.bsvibe.dev

# ── Runtime ─────────────────────────────────────────────────────
SAFE_MODE=true
LOG_LEVEL=INFO
