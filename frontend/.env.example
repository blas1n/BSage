# Public env vars (inlined into the client bundle by Next.js).
# Both NEXT_PUBLIC_* (canonical) and VITE_* (legacy) are accepted at runtime
# for backward compatibility during the Phase Z migration.
NEXT_PUBLIC_API_URL=https://api-sage.bsvibe.dev/api
NEXT_PUBLIC_WS_URL=wss://api-sage.bsvibe.dev/ws
NEXT_PUBLIC_AUTH_URL=https://auth.bsvibe.dev

# Server-only — used by next.config.mjs `rewrites()` to proxy /api/* in dev.
# Defaults to https://api-sage.bsvibe.dev when unset.
# BSAGE_API_TARGET=http://127.0.0.1:8000
